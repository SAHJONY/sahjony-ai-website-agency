# Copy this file to .env.local and fill in your real values.
# In production, set these in Vercel → Settings → Environment Variables.
# NEVER commit real secrets — .env.local is gitignored.

# Claude (Anthropic) API key — https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the Claude model used by /api/generate
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# --- Fallback "second brain" engines (autonomous rotation) ---
# If Claude fails or is unset, /api/generate auto-rolls to these free engines.

# NVIDIA NIM (free) — https://build.nvidia.com → your profile → "Get API Key" (nvapi-...)
# Rotates across a pool of free models; a throttled model auto-rolls to the next.
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override the rotation pool (comma-separated NIM model ids)
# NVIDIA_MODELS=meta/llama-3.3-70b-instruct,nvidia/llama-3.1-nemotron-70b-instruct,meta/llama-3.1-405b-instruct,mistralai/mixtral-8x22b-instruct-v0.1,google/gemma-2-27b-it,deepseek-ai/deepseek-r1

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# Grok (xAI) — https://console.x.ai
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
XAI_MODEL=grok-2-latest

# Google Gemini (free tier) — https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override the Gemini model
GEMINI_MODEL=gemini-2.5-flash

# GLM (Z.ai / Zhipu) — https://z.ai  (OpenAI-compatible)
ZAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ZAI_MODEL=glm-4.6
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# --- AI image generation (/api/image) — for stunning, non-generic hero art ---
# RECOMMENDED: FLUX 1.1 [pro] via fal.ai (top-tier photoreal). Get a key at fal.ai/dashboard/keys
FAL_API_KEY=xxxxxxxx
# FAL_IMAGE_URL=https://fal.run/fal-ai/flux-pro/v1.1   # or flux-pro/v1.1-ultra, flux/dev, etc.
#
# OR a generic OpenAI-images-compatible provider:
# IMAGE_API_URL=https://api.provider.com/v1/images/generations
# IMAGE_API_KEY=xxxxxxxx
# IMAGE_MODEL=gpt-image-1
# OR Higgsfield:
# HIGGSFIELD_API_KEY=xxxxxxxx
# HIGGSFIELD_API_URL=https://api.higgsfield.ai/v1/images/generations
# HIGGSFIELD_MODEL=soul
# (If none set, it falls back to OPENAI_API_KEY above with gpt-image-1.)

# --- Lead finder (Google Places) ---
# Enable "Places API" in Google Cloud, then create an API key.
GOOGLE_PLACES_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Outreach: email (Resend) and/or SMS (Twilio) ---
# Email — https://resend.com  (verify a domain, or use onboarding@resend.dev for tests)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
OUTREACH_FROM=hello@frontdeskagents.com
# SMS — https://twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM=+1xxxxxxxxxx

# --- Payments (Stripe) ---
# Secret key from https://dashboard.stripe.com/apikeys (sk_live_… or sk_test_…)
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
# Optional: gate the webhook URL. Configure the Stripe webhook as
#   https://YOURDOMAIN/api/stripe-webhook?token=YOUR_TOKEN  (event: checkout.session.completed)
WEBHOOK_TOKEN=choose-a-random-token
# To offer Cash App Pay + installments (Affirm/Klarna/Afterpay) on the Stripe link,
# just enable those methods in Stripe Dashboard → Settings → Payment methods.
# Installment PLANS (split the build into N monthly charges) need no extra setup.

# --- Payments (Square) — optional, hosted payment links ---
# From https://developer.squareup.com/apps  (Access token + a Location ID)
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
# SQUARE_ENV=sandbox        # use Square's sandbox while testing (default: production)

# --- Manual payments (Zelle + Cash App $cashtag) — optional, no API ---
# Shown to the client to pay you directly (no fees; installments by agreement).
ZELLE_HANDLE=               # your Zelle email or phone, e.g. pay@yourbiz.com
CASHAPP_CASHTAG=            # your Cash App tag, e.g. $YourBiz
# Optional: canonical app URL for Stripe success/cancel redirects (else inferred)
APP_URL=https://frontdeskagents.com

# --- Secrets manager (dashboard → Settings) ---
# Required to add/delete AI keys from the dashboard at runtime. Pick a strong
# password. Without it, the secrets manager stays locked. Keys set here in env
# always override anything stored in the dashboard.
ADMIN_PASSWORD=choose-a-strong-admin-password

# Upstash Redis (REST) — https://console.upstash.com → your DB → REST API tab
# (Required for the dashboard, contact inbox, AND the runtime secrets manager.)
UPSTASH_REDIS_REST_URL=https://your-db-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
