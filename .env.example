# Copy this file to .env.local and fill in your real values.
# In production, set these in Vercel → Settings → Environment Variables.
# NEVER commit real secrets — .env.local is gitignored.

# Claude (Anthropic) API key — https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the Claude model used by /api/generate
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# --- Fallback "second brain" engines (autonomous rotation) ---
# If Claude fails or is unset, /api/generate auto-rolls to these free engines.

# NVIDIA NIM (free) — https://build.nvidia.com → your profile → "Get API Key" (nvapi-...)
# Rotates across a pool of free models; a throttled model auto-rolls to the next.
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override the rotation pool (comma-separated NIM model ids)
# NVIDIA_MODELS=meta/llama-3.3-70b-instruct,nvidia/llama-3.1-nemotron-70b-instruct,meta/llama-3.1-405b-instruct,mistralai/mixtral-8x22b-instruct-v0.1,google/gemma-2-27b-it,deepseek-ai/deepseek-r1

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# Grok (xAI) — https://console.x.ai
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
XAI_MODEL=grok-2-latest

# Google Gemini (free tier) — https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override the Gemini model
GEMINI_MODEL=gemini-2.5-flash

# GLM (Z.ai / Zhipu) — https://z.ai  (OpenAI-compatible)
ZAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ZAI_MODEL=glm-4.6
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# --- AI visuals: images + video (/api/image) — cinematic 8K, no generic art ---
# PRIMARY engine = Higgsfield (cinematic 8K images + video). Claude is the design
# brain; OpenAI Images is the fallback engine. Leave IMAGE_PROVIDER unset to
# auto-prefer Higgsfield when its keys are present.
IMAGE_PROVIDER=higgsfield                 # higgsfield (primary) | fal | custom | openai
HIGGSFIELD_KEY_ID=xxxxxxxx                # primary: Higgsfield key id + secret
HIGGSFIELD_KEY_SECRET=xxxxxxxx
# HIGGSFIELD_API_KEY=xxxxxxxx             # (alt single-key form "KEY_ID:KEY_SECRET")
# HIGGSFIELD_API_URL=https://platform.higgsfield.ai/flux-pro/kontext/max/text-to-image
# HIGGSFIELD_VIDEO_URL=https://platform.higgsfield.ai/text-to-video   # POST {mode:"video"} to /api/image
# HIGGSFIELD_VIDEO_POLL_MS=55000          # video render poll budget (stay < maxDuration)
#
# FULL cinematic production (optional, premium): OpenMontage agentic video studio.
# It's Python/FFmpeg/Remotion and can't run on Vercel, so host it as a render
# worker (see ~/OpenMontage/webbuilder-worker) and point the builder at it. When
# set, the builder's video button produces full OpenMontage films (async job +
# poll) and falls back to a Higgsfield clip if the worker is unavailable.
# OPENMONTAGE_URL=https://your-openmontage-worker.example.com
# OPENMONTAGE_TOKEN=shared_bearer_token
#
# Fallback engines:
FAL_API_KEY=xxxxxxxx                      # FLUX 1.1 [pro] via fal.ai
# FAL_IMAGE_URL=https://fal.run/fal-ai/flux-pro/v1.1
# IMAGE_API_URL=https://api.provider.com/v1/images/generations  # generic OpenAI-images-style
# IMAGE_API_KEY=xxxxxxxx
# IMAGE_MODEL=gpt-image-1
# (If none set, it falls back to OPENAI_API_KEY above with gpt-image-1.)

# --- Lead finder + AUTONOMOUS BUILDER (Google Places API NEW) ---
# Enable "Places API (New)" in Google Cloud, then create an API key. Powers both
# the dashboard lead finder AND the builder's 🤖 Auto mode (name+address → it
# researches the business: category, phone, hours, rating, reviews, photos,
# social links, and every branch — then the AI designs the whole site).
GOOGLE_PLACES_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Autonomous WORLDWIDE lead sweep (cron) ---
# A daily cron hits GET /api/leads-find?sweep=1 and rotates through a global grid
# of metros × industries, finding businesses with NO website or an OUTDATED one,
# scoring + deduping them into Redis (fda:sweep:leads). Manual run: POST
# /api/leads-find { sweep:true }. CRON_SECRET gates the cron path (Vercel Cron
# attaches it as a Bearer token). On Vercel Hobby, crons run once/day.
CRON_SECRET=random_long_string

# --- Outreach: email (Resend) and/or SMS (Twilio) ---
# Email — https://resend.com  (verify a domain, or use onboarding@resend.dev for tests)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
OUTREACH_FROM=hello@frontdeskagents.com
# SMS — https://twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM=+1xxxxxxxxxx

# --- Social media accounts (autonomous marketing) ---
# Paste your full profile URLs. They appear across the app (site footer + any
# social bar) and power the Marketing kit. You can also set/override these in the
# dashboard → Marketing (stored in Upstash), no redeploy needed.
SOCIAL_FACEBOOK=
SOCIAL_INSTAGRAM=
SOCIAL_TIKTOK=
SOCIAL_YOUTUBE=
SOCIAL_X=                    # X/Twitter (SOCIAL_TWITTER also accepted)
SOCIAL_LINKEDIN=
SOCIAL_THREADS=
SOCIAL_PINTEREST=
SOCIAL_WHATSAPP=
SOCIAL_TELEGRAM=
SOCIAL_GOOGLE=              # Google Business profile
SOCIAL_YELP=

# Autonomous auto-posting: a catch webhook from Zapier / Make / Buffer / n8n.
# The dashboard → Marketing "🚀 Auto-post" button POSTs {text, link, at} here,
# and your scheduler fans it out to every connected network. This keeps social
# API/OAuth complexity out of the app while still enabling autonomous posting.
MARKETING_WEBHOOK_URL=

# ============================ PAYMENTS ======================================
# Which method LEADS on the options you send clients:
#   manual (default) = Zelle + Cash App first — no processor fees, best while the
#                      business is getting started. Card/Square shown as backup.
#   stripe           = lead with card / Cash App Pay / installments (flip this
#                      once volume/profits justify ~3% card fees).
# The primary method is Zelle + Cash App below; set the two handles to enable it.
PAYMENTS_PRIMARY=manual

# --- Payments (Stripe) — optional, secondary until PAYMENTS_PRIMARY=stripe ---
# Secret key from https://dashboard.stripe.com/apikeys (sk_live_… or sk_test_…)
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
# Optional: gate the webhook URL. Configure the Stripe webhook as
#   https://YOURDOMAIN/api/stripe-webhook?token=YOUR_TOKEN  (event: checkout.session.completed)
WEBHOOK_TOKEN=choose-a-random-token
# To offer Cash App Pay + installments (Affirm/Klarna/Afterpay) on the Stripe link,
# just enable those methods in Stripe Dashboard → Settings → Payment methods.
# Installment PLANS (split the build into N monthly charges) need no extra setup.

# --- Payments (Square) — optional, hosted payment links ---
# From https://developer.squareup.com/apps  (Access token + a Location ID)
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
# SQUARE_ENV=sandbox        # use Square's sandbox while testing (default: production)

# --- Manual payments (Zelle + Cash App $cashtag) — optional, no API ---
# Shown to the client to pay you directly (no fees; installments by agreement).
ZELLE_HANDLE=               # your Zelle email or phone, e.g. pay@yourbiz.com
CASHAPP_CASHTAG=            # your Cash App tag, e.g. $YourBiz
# Optional: canonical app URL for Stripe success/cancel redirects (else inferred)
APP_URL=https://frontdeskagents.com

# --- Secrets manager (dashboard → Settings) ---
# Required to add/delete AI keys from the dashboard at runtime. Pick a strong
# password. Without it, the secrets manager stays locked. Keys set here in env
# always override anything stored in the dashboard.
ADMIN_PASSWORD=choose-a-strong-admin-password

# Upstash Redis (REST) — https://console.upstash.com → your DB → REST API tab
# (Required for the dashboard, contact inbox, AND the runtime secrets manager.)
UPSTASH_REDIS_REST_URL=https://your-db-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# --- Telegram channel (client chat + lead alerts) — optional ---
# Bot token from @BotFather; owner chat = your numeric Telegram user id
# (start @Webbuildagency_bot, message it, the app shows your chat id on forward).
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT=
# TELEGRAM_WEBHOOK_SECRET=optional-random-string   # validates Telegram webhook calls

# ============================================================================
# AVA — AI receptionist (blended from FrontDesk-Agents)
# Chat works out of the box on any configured AI engine (no extra key needed).
# ============================================================================
AVA_NAME=Ava
# Optional voice/telephony receptionist (Bland) — adds inbound/outbound calls.
# Voice needs a webhook endpoint; enable when on a plan with spare functions.
# BLAND_API_KEY=org_xxx
# BLAND_INBOUND_NUMBER=+1XXXXXXXXXX
# BLAND_CALLER_ID=+1XXXXXXXXXX
# BLAND_AGENT_NAME=Ava
# BLAND_DEFAULT_LANGUAGE=babel
# BLAND_WEBHOOK_SECRET=random_long_string

# --- More payment options (from FrontDesk-Agents) ---
# PAYPAL_CLIENT_ID=xxx
# PAYPAL_CLIENT_SECRET=xxx

# --- Email via SMTP (alternative to Resend) ---
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USER=owner@outlook.com
# SMTP_PASS=xxx
# NOTIFY_EMAIL=owner@example.com

# --- Ava Voice (Bland.ai) — inbound + outbound AI phone calls ---
# Get your key at https://app.bland.ai  → Settings → API Key.
# BLAND_API_KEY=org_xxx
# BLAND_WEBHOOK_SECRET=random_long_string      # gates POST /api/bland (inbound results)
# BLAND_OUTBOUND_NUMBER=+1XXXXXXXXXX           # optional caller ID for outbound
# BLAND_AGENT_NAME=Ava
# BLAND_DEFAULT_LANGUAGE=babel                 # Bland "babel" = auto multilingual
# NOTIFY_EMAIL=owner@example.com               # where Ava call/lead notifications go (needs RESEND_API_KEY)
