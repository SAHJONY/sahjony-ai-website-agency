{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/image.js": { "maxDuration": 60 },
    "api/generate.js": { "maxDuration": 60 },
    "api/leads-find.js": { "maxDuration": 30 },
    "api/contact.js": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/s/:slug", "destination": "/api/site?slug=:slug" },
    { "source": "/api/track", "destination": "/api/health" },
    { "source": "/api/login", "destination": "/api/data?action=login" },
    { "source": "/api/telegram", "destination": "/api/contact?tg=1" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [{ "key": "Content-Type", "value": "application/manifest+json" }]
    }
  ]
}
